GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
DATABASE_URL=sqlite:///./po_matching.db
INBOX_WATCH_FOLDER=./sample_data/emails
LOG_LEVEL=INFO
DISCREPANCY_TOLERANCE_PERCENT=2.0

# IMAP Configuration
ENABLE_IMAP=False
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_app_password_here

# Airtable Configuration (Optional)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Invoices

# Security Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password
JWT_SECRET_KEY=super_secret_key_please_change
